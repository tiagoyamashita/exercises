# syntax=docker/dockerfile:1
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY index.html tsconfig.json vite.config.ts ./
COPY src ./src

ARG VITE_EXERCISES_JAVA_EMBED_URL=http://127.0.0.1:8080/
ARG VITE_EXERCISES_PYTHON_EMBED_URL=http://127.0.0.1:5000/
ARG VITE_EXERCISES_RUST_EMBED_URL=http://127.0.0.1:8082/
ARG VITE_GRAFANA_EMBED_URL=http://127.0.0.1:3000/
ARG VITE_PROMETHEUS_EMBED_URL=http://127.0.0.1:9090/
ARG VITE_ELASTICSEARCH_EMBED_URL=http://127.0.0.1:9200/
ARG VITE_KIBANA_EMBED_URL=http://127.0.0.1:5601/

ENV VITE_EXERCISES_JAVA_EMBED_URL=$VITE_EXERCISES_JAVA_EMBED_URL \
    VITE_EXERCISES_PYTHON_EMBED_URL=$VITE_EXERCISES_PYTHON_EMBED_URL \
    VITE_EXERCISES_RUST_EMBED_URL=$VITE_EXERCISES_RUST_EMBED_URL \
    VITE_GRAFANA_EMBED_URL=$VITE_GRAFANA_EMBED_URL \
    VITE_PROMETHEUS_EMBED_URL=$VITE_PROMETHEUS_EMBED_URL \
    VITE_ELASTICSEARCH_EMBED_URL=$VITE_ELASTICSEARCH_EMBED_URL \
    VITE_KIBANA_EMBED_URL=$VITE_KIBANA_EMBED_URL

RUN npm run build

FROM docker.io/library/nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 5173
